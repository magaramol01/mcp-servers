# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=fo-shore

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
EMISSION_ENGINEER_POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/emission_engineer
# Optional tenant-aware CII fuel tag config:
# EMISSION_ENGINEER_CII_FUEL_CONFIG_PATH=/absolute/path/to/fuel-config.json
# EMISSION_ENGINEER_CII_FUEL_CONFIG_JSON={"tenantA":{"ciiData":{"fuelData":[...]}}}

# ─── Logging ─────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info
