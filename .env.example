# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=fo-shore

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
EMISSION_ENGINEER_POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/emission_engineer
# CII fuel tag mapping: edit packages/mcp-emission-engineer/src/conf/conf.json (or rely on built-in defaults if absent).

# ─── Logging ─────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info
