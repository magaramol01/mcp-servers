# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=fo-shore

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
EMISSION_ENGINEER_POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/emission_engineer
# CII fuel tag mapping: edit packages/mcp-emission-engineer/src/conf/conf.json (or rely on built-in defaults if absent).
ALERTS_SERVICE_POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ─── Technical Advisory RAG ──────────────────────────────────────────────────
PAGEINDEX_API_KEY=your_pageindex_api_key
GCS_BUCKET_NAME=your_gcs_bucket_name
TECHNICAL_ADVISORY_GCS_PREFIX=optional/gcs/prefix/
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GEMINI_API_KEY=your_gemini_api_key
TECHNICAL_ADVISORY_HOST=0.0.0.0
TECHNICAL_ADVISORY_PORT=3000

# ─── Logging ─────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info
